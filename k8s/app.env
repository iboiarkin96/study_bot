# =============================================================================
# Local Kubernetes — non-secret pod environment (single source of truth)
# =============================================================================
#
# This file drives `k8s/configmap.yaml` (generated). Edit here, then run:
#   make k8s-render-configmap
# or `make docs-fix` / `make verify` (docs pipeline includes the render step).
#
# Do NOT put passwords or production API keys here — use a Kubernetes Secret and
# wire `secretRef` in the Deployment when you switch to APP_ENV=qa and real keys.
#
# Human-readable catalog of all variables (including LLM keys for scripts) remains
# in `env/example`. Values below are the subset needed for the container plus
# overrides for in-cluster networking (APP_HOST, SQLITE_DB_PATH, LOG_DIR).
#
# =============================================================================

APP_NAME=Study App API
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
SQLITE_DB_PATH=/data/study_app.db
LOG_DIR=/tmp/logs
LOG_FILE_NAME=app.log
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_SERVICE_NAME=study-app-api
CORS_ALLOW_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-API-Key,Idempotency-Key,X-Request-Id
CORS_EXPOSE_HEADERS=X-Request-Id,X-RateLimit-Limit,X-RateLimit-Remaining,Retry-After
CORS_ALLOW_CREDENTIALS=false
API_BODY_MAX_BYTES=1048576
API_RATE_LIMIT_REQUESTS=120
API_RATE_LIMIT_WINDOW_SECONDS=60
API_AUTH_STRATEGY=mock_api_key
# API_MOCK_API_KEY omitted: dev uses the built-in default from app/core/config.py (same as env/example).
# For qa in-cluster, add a Kubernetes Secret and secretRef on the Deployment — see k8s/secret.example.yaml.
API_AUTH_HEADER=X-API-Key
API_PROTECTED_PREFIX=/api/v1
METRICS_ENABLED=true
METRICS_PATH=/metrics
READINESS_DB_TIMEOUT_MS=500
