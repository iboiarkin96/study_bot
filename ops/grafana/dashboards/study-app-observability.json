{
  "id": null,
  "uid": "study-app-observability",
  "title": "Study App Observability",
  "description": "Local hosts: API 127.0.0.1:8000, Prometheus 127.0.0.1:9090, Grafana 127.0.0.1:3001.",
  "tags": ["study-app", "api"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "links": [
    {
      "title": "Prometheus Targets",
      "type": "link",
      "url": "http://127.0.0.1:9090/targets",
      "targetBlank": true
    },
    {
      "title": "Prometheus: Request Rate (RPS)",
      "type": "link",
      "url": "http://127.0.0.1:9090/graph?g0.expr=sum%28rate%28http_requests_total%5B1m%5D%29%29&g0.tab=0",
      "targetBlank": true
    },
    {
      "title": "Prometheus: Error Rate (%)",
      "type": "link",
      "url": "http://127.0.0.1:9090/graph?g0.expr=100%20*%20sum%28rate%28http_requests_total%7Bstatus_code%3D~%225..%7C4..%22%7D%5B5m%5D%29%29%20%2F%20sum%28rate%28http_requests_total%5B5m%5D%29%29&g0.tab=0",
      "targetBlank": true
    },
    {
      "title": "Prometheus: API p95 (ms)",
      "type": "link",
      "url": "http://127.0.0.1:9090/graph?g0.expr=1000%20*%20histogram_quantile%280.95%2C%20sum%28rate%28http_request_duration_seconds_bucket%5B5m%5D%29%29%20by%20%28le%29%29&g0.tab=0",
      "targetBlank": true
    },
    {
      "title": "Prometheus: DB p95 (ms)",
      "type": "link",
      "url": "http://127.0.0.1:9090/graph?g0.expr=1000%20*%20histogram_quantile%280.95%2C%20sum%28rate%28db_operation_duration_seconds_bucket%5B5m%5D%29%29%20by%20%28le%29%29&g0.tab=0",
      "targetBlank": true
    }
  ],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request Rate (rps)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m]))",
          "legendFormat": "all requests"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Error Rate (%)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "100 * sum(rate(http_requests_total{status_code=~\"5..|4..\"}[5m])) / sum(rate(http_requests_total[5m]))",
          "legendFormat": "error rate"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "API Latency P95 (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "1000 * histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "DB Latency P95 (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "1000 * histogram_quantile(0.95, sum(rate(db_operation_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    }
  ]
}
