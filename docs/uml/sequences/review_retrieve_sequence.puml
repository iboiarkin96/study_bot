@startuml
title ETR Study API — Review (retrieve outcome)

autonumber
hide footbox

actor "Integrator" as Client
boundary "HTTP API" as Api
control "ConspectusService" as Service
participant "SchedulePolicy" as Policy
database "DB (transaction)" as Db

Client -> Api: POST .../actions/review
activate Api
Api -> Service: apply_review(user, id, tag)
activate Service
Service -> Db: SELECT conspectus + schedule (ownership)

alt not found
  Service --> Api: 404
  deactivate Service
  Api --> Client: 404
  deactivate Api
else found
  Service -> Policy: next schedule (tag, current)
  Policy --> Service
  Service -> Db: UPDATE schedule snapshot
  Service -> Db: INSERT conspectus_review_log (before/after JSON)
  note right: Option A: reviews live here;\nno duplicate in conspectus_events.
  Db --> Service
  Service --> Api: 200 + body
  deactivate Service
  Api --> Client: 200 OK
  deactivate Api
end

@enduml
