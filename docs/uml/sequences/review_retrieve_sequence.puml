@startuml
title Study App - Sequence: Review Retrieve

autonumber
hide footbox

actor "Client app" as Client
boundary "HTTP API" as Api
control "RetrieveService" as Service
database "Repos + DB" as RepoDb

Client -> Api: POST /conspectuses/{id}/review
activate Api
Api -> Api: validate payload

alt invalid payload
  Api --> Client: 422 Validation Error
  deactivate Api
else valid payload
  Api -> Service: apply_review(user_id, id, tag)
  activate Service
  Service -> RepoDb: load conspectus
  RepoDb --> Service: record or empty

  alt conspectus not found
    Service --> Api: NotFound
    deactivate Service
    Api --> Client: 404 Not Found
    deactivate Api
  else found
    Service -> Service: compute next slot
    Service -> RepoDb: update slot + insert log
    alt transaction failed
      Service --> Api: Conflict
      deactivate Service
      Api --> Client: 409 Conflict
      deactivate Api
    else transaction success
      Service --> Api: ReviewResponse
      deactivate Service
      Api --> Client: 200 OK
      deactivate Api
    end
  end
end

@enduml
