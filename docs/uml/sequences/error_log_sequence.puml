@startuml
title Study App - Sequence: Create Error Log

autonumber
hide footbox

actor "Client app" as Client
boundary "HTTP API" as Api
control "ErrorLogService" as Service
database "Repos + DB" as RepoDb

Client -> Api: POST /errors
activate Api
Api -> Api: validate payload

alt invalid payload
  Api --> Client: 422 Validation Error
  deactivate Api
else valid payload
  Api -> Service: add_error(user_id, payload)
  activate Service
  Service -> RepoDb: verify owner and conspectus
  RepoDb --> Service: found or missing

  alt not found
    Service --> Api: NotFound
    deactivate Service
    Api --> Client: 404 Not Found
    deactivate Api
  else found
    Service -> RepoDb: insert error log
    alt transaction failed
      Service --> Api: Conflict
      deactivate Service
      Api --> Client: 409 Conflict
      deactivate Api
    else transaction success
      Service --> Api: ErrorLogResponse
      deactivate Service
      Api --> Client: 201 Created
      deactivate Api
    end
  end
end

@enduml
