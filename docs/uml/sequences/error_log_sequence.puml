@startuml
title ETR Study API — Create learning error log

autonumber
hide footbox
' Same participant order as create/review sequences (Policy between service and DB). This flow
' does not call Policy; the lifeline stays idle so the export width matches the other diagrams.
skinparam ParticipantPadding 71

actor "Integrator" as Client
boundary "HTTP API" as Api
control "ErrorLogService" as Service
participant "SchedulePolicy" as Policy
database "DB" as Db

Client -> Api: POST /api/v1/errors
activate Api
Api -> Service: create(user, payload)
activate Service
Service -> Db: verify user / optional conspectus FK

alt not found
  Service --> Api: 404
  deactivate Service
  Api --> Client: 404
  deactivate Api
else ok
  Service -> Db: INSERT learning_errors
  Service --> Api: DTO
  deactivate Service
  Api --> Client: 201 Created
  deactivate Api
end

@enduml
