' Shared PlantUML skin (injected after @startuml by scripts/regenerate_docs.py for Kroki single-file render)
skinparam shadowing false
skinparam linetype ortho
skinparam componentStyle rectangle
skinparam packageStyle rectangle
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 9
' Moderate spacing (defaults were too tight; very large values looked empty). Tweak here only.
skinparam nodesep 20
skinparam ranksep 18
skinparam Padding 6
skinparam dpi 100
skinparam roundcorner 10
skinparam ArrowColor #334155
skinparam ArrowThickness 1.1
skinparam ArrowFontSize 8
skinparam PackageBorderColor #94a3b8
skinparam PackageBackgroundColor #F8FAFC
skinparam RectangleBorderColor #2563EB
skinparam RectangleBackgroundColor #EFF6FF
skinparam DatabaseBorderColor #EA580C
skinparam DatabaseBackgroundColor #FFF7ED
skinparam NodeBorderColor #475569
skinparam NodeBackgroundColor #F8FAFC
skinparam ActorBorderColor #059669
skinparam ActorBackgroundColor #ECFDF5
skinparam ParticipantBorderColor #2563EB
skinparam ParticipantBackgroundColor #EFF6FF
skinparam SequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam maxMessageSize 90
skinparam ParticipantPadding 14
skinparam BoxPadding 8
