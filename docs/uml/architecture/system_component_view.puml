@startuml
title Study App - C4 L3 Component View (Users)

top to bottom direction

actor "Client" as Client

package "Presentation — HTTP API" as Pres {
  [User router\nFastAPI] as Router
  [Schemas\nPydantic] as Schema
  Router -[hidden]right- Schema
}

package "Application — services" as AppPkg {
  [UserService] as Service
}

package "Persistence — data access" as PerPkg {
  [UserRepository] as Repo
  [Session factory\nSQLAlchemy] as Session
  Repo -[hidden]right- Session
}

database "SQLite\nstudy_app.db" as Db

Client --> Router : HTTPS / JSON
Router --> Schema : bind & validate
Router --> Service : use case
Service --> Repo : read / write
Repo --> Session : ORM & unit of work
Session --> Db : SQL

@enduml
