@startuml
title Makefile composite targets (dependency order)

top to bottom direction

package "make fix" {
  rectangle "format-fix" as f1
  rectangle "lint-fix" as f2
  rectangle "docs-fix" as f3
  f1 -right-> f2
  f2 -right-> f3
}

package "make verify" {
  rectangle "deps-audit" as m0
  rectangle "lint-check" as m1
  rectangle "type-check" as m2
  rectangle "openapi-check" as m3
  rectangle "contract-test" as m4
  rectangle "test" as m5
  rectangle "docs-check" as m6
  rectangle "docs-a11y-check" as m7
  m0 -down-> m1
  m1 -down-> m2
  m2 -down-> m3
  m3 -down-> m4
  m4 -down-> m5
  m5 -down-> m6
  m6 -down-> m7
}

package "make release-check" {
  rectangle "env-check" as rc1
  rectangle "deps-audit" as rc2
  rectangle "verify" as rc3
  rc1 -down-> rc2
  rc2 -down-> rc3
}

package "make release" {
  rectangle "release-check" as rel1
  rectangle "DEPLOY_CMD" as rel2
  rel1 -down-> rel2
}

@enduml
