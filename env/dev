# Loaded after .env when APP_ENV=dev
APP_NAME="ETR Study App API"
APP_ENV=dev
APP_HOST=127.0.0.1
APP_PORT=8000
SQLITE_DB_PATH=study_app.db

# Logging config (json = NDJSON with request_id field for Kibana/Elasticsearch; override with LOG_FORMAT=text)
LOG_DIR=logs
LOG_FILE_NAME=app.log
LOG_LEVEL=DEBUG
LOG_FORMAT=json
LOG_SERVICE_NAME=study-app-api

# API security defaults
CORS_ALLOW_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:8765,http://localhost:8765
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-API-Key,Idempotency-Key,X-Request-Id
CORS_EXPOSE_HEADERS=X-Request-Id,X-RateLimit-Limit,X-RateLimit-Remaining,Retry-After
CORS_ALLOW_CREDENTIALS=false
API_BODY_MAX_BYTES=1048576
API_RATE_LIMIT_REQUESTS=60
API_RATE_LIMIT_WINDOW_SECONDS=60
# Local load runs: make run-loadtest-api / run-loadtest-api-serve set
# API_RATE_LIMIT_REQUESTS=1000000000 (unless API_RATE_LIMIT_REQUESTS_LOADTEST is set); otherwise raise limits here.
API_AUTH_STRATEGY=mock_api_key
API_MOCK_API_KEY=local-dev-key
API_AUTH_HEADER=X-API-Key
API_PROTECTED_PREFIX=/api/v1

# Optional: expose GET /__loadtest/http500 (HTTP 500) for local traffic (tools/load_testing)
LOADTEST_HTTP_500=false

# make run-loadtest-api — runner defaults (override count with LOADTEST_TOTAL_REQUESTS if needed)
LOADTEST_DEFAULT_TOTAL_REQUESTS=100000
LOADTEST_DEFAULT_DELAY_MS=0

# Metrics and readiness
METRICS_ENABLED=true
METRICS_PATH=/metrics
READINESS_DB_TIMEOUT_MS=250
METRICS_BUCKETS_HTTP=0.005,0.01,0.025,0.05,0.1,0.25,0.5,1,2.5,5
METRICS_BUCKETS_DB=0.001,0.0025,0.005,0.01,0.025,0.05,0.1,0.25

# Observability local hosts (for helper scripts and docs)
OBS_API_HOST=127.0.0.1
OBS_API_PORT=8000
OBS_PROM_HOST=127.0.0.1
OBS_PROM_PORT=9090
OBS_GRAF_HOST=127.0.0.1
OBS_GRAF_PORT=3001

# Dockerized observability stack parameters
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
PROMETHEUS_SCRAPE_TARGET=host.docker.internal:8000
PROMETHEUS_READY_PROBE_URL=http://host.docker.internal:8000/ready
BLACKBOX_EXPORTER_PORT=9115
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# LLM helpers (changelog draft / scripts/llm_ping.py): put secrets in root `.env`, not here.
# See env/example — e.g. OPENROUTER_API_KEY + optional OPENAI_MODEL.
